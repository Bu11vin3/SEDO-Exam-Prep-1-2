pipeline{
    agent any 
    stages{

        stage('Dotnet Restore'){
            when {
                anyOf {
                    branch 'main'
                    branch 'feature'
                }
            }
            steps{
                bat "dotnet restore"
            }
        }
        stage('Dotnet Build'){
            when {
                anyOf {
                    branch 'main'
                    branch 'feature'
                }
            }
            steps{
                bat "dotnet build"
            }
        }
        stage('Dotnet Test'){
            when {
                anyOf {
                    branch 'main'
                    branch 'feature'
                }
            }
            steps{
                bat "dotnet test"
            }
        }
    }
}